# ===========================================
# Am I Getting Rage Bait by a Bot on X? — Configuration
# ===========================================
# Copier ce fichier vers .env et remplir les valeurs
# cp .env.example .env

# --- Twitter API ---
TWITTER_API_KEY=your_twitterapi_io_key_here

# --- Twitter Credentials (pour Twikit, gratuit) ---
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=

# --- PostgreSQL ---
POSTGRES_USER=amirb
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=amirb_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- App ---
SECRET_KEY=generate_a_random_secret_key_here
ENVIRONMENT=development
DEBUG=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]
