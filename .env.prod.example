# ===========================================
# Production environment — Am I Getting Rage Bait by a Bot on X?
# ===========================================
# Copy to .env.prod and fill in real values
# cp .env.prod.example .env.prod

# --- Domain & TLS ---
DOMAIN=yourdomain.com
ACME_EMAIL=your-email@example.com

# --- PostgreSQL ---
POSTGRES_USER=amirb
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=amirb_db
DATABASE_URL=postgresql+asyncpg://amirb:CHANGE_ME_STRONG_PASSWORD@db:5432/amirb_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- App ---
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ENVIRONMENT=production
DEBUG=false

# --- CORS ---
CORS_ORIGINS=["https://yourdomain.com"]

# --- Twitter API ---
TWITTER_API_KEY=your_twitter_api_key

# --- Twitter Credentials (Twikit) ---
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email
TWITTER_PASSWORD=your_twitter_password
